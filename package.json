{
  "name": "adfinem",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "adfinem": "tsx src/cli.ts",
    "cli": "tsx src/cli.ts",
    "test": "tsx --test tests/api-only.test.ts",
    "validate": "tsx src/cli.ts validate scenarios/smoke/account-processing-smoke.yaml",
    "smoke:dry": "tsx src/cli.ts run scenarios/smoke/account-processing-smoke.yaml --env local --dry-run",
    "web:build": "vite build",
    "app": "npm run web:build && tsx src/app/server.ts"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "axios": "^1.9.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "elkjs": "^0.11.1",
    "jsonpath-plus": "^10.3.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "ssh2": "^1.16.0",
    "yaml": "^2.7.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.31",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^8.0.10"
  },
  "optionalDependencies": {
    "oracledb": "^6.8.0"
  }
}
